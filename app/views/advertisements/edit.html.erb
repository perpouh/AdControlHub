<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- ヘッダー -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">広告編集</h1>
          <p class="mt-2 text-sm text-gray-600">
            「<%= @advertisement.title %>」を編集します
          </p>
        </div>
        <div class="flex space-x-3">
          <%= link_to advertisement_path(@advertisement), 
              class: 'inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500' do %>
            <svg class="-ml-1 mr-2 h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            詳細表示
          <% end %>
          <%= link_to advertisements_path, 
              class: 'inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500' do %>
            <svg class="-ml-1 mr-2 h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            一覧に戻る
          <% end %>
        </div>
      </div>
    </div>

    <!-- 現在の情報 -->
    <div class="bg-white shadow rounded-lg p-6 mb-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">現在の情報</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <dt class="text-sm font-medium text-gray-500">タイトル</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @advertisement.title %></dd>
        </div>
        
        <div>
          <dt class="text-sm font-medium text-gray-500">広告種別</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full 
                        <%= @advertisement.ad_type == 'image' ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800' %>">
              <%= @advertisement.ad_type == 'image' ? '画像広告' : '動画広告' %>
            </span>
          </dd>
        </div>
        
        <div>
          <dt class="text-sm font-medium text-gray-500">広告サイズ</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">
              <%= case @advertisement.ad_size
                  when 'vertical' then '縦長'
                  when 'horizontal' then '横長'
                  when 'square' then '正方形'
                  end %>
            </span>
          </dd>
        </div>
        
        <div>
          <dt class="text-sm font-medium text-gray-500">ステータス</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <% if @advertisement.active? %>
              <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                アクティブ
              </span>
            <% else %>
              <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">
                非アクティブ
              </span>
            <% end %>
          </dd>
        </div>
        
        <div class="md:col-span-2">
          <dt class="text-sm font-medium text-gray-500">リンクURL</dt>
          <dd class="mt-1 text-sm text-gray-900 break-all">
            <%= link_to @advertisement.link_url, @advertisement.link_url, 
                target: '_blank', 
                class: 'text-blue-600 hover:text-blue-800 underline' %>
          </dd>
        </div>
        
        <% if @advertisement.image_url.present? %>
          <div class="md:col-span-2">
            <dt class="text-sm font-medium text-gray-500">画像URL</dt>
            <dd class="mt-1 text-sm text-gray-900 break-all">
              <%= link_to @advertisement.image_url, @advertisement.image_url, 
                  target: '_blank', 
                  class: 'text-blue-600 hover:text-blue-800 underline' %>
            </dd>
          </div>
        <% end %>
        
        <% if @advertisement.alt_text.present? %>
          <div class="md:col-span-2">
            <dt class="text-sm font-medium text-gray-500">代替テキスト</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @advertisement.alt_text %></dd>
          </div>
        <% end %>
        
        <% if @advertisement.tags.any? %>
          <div class="md:col-span-2">
            <dt class="text-sm font-medium text-gray-500">タグ</dt>
            <dd class="mt-1 flex flex-wrap gap-2">
              <% @advertisement.tags.each do |tag| %>
                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-indigo-100 text-indigo-800">
                  <%= tag %>
                </span>
              <% end %>
            </dd>
          </div>
        <% end %>
      </div>
    </div>

    <!-- フォーム -->
    <%= render 'form', advertisement: @advertisement %>
  </div>
</div>
