<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">広告管理</h1>
    <%= link_to '新規作成', new_advertisement_path, class: 'bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded' %>
  </div>

  <!-- 検索フォーム -->
  <div class="bg-white shadow-md rounded-lg p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4">検索条件</h2>
    <%= search_form_for @q, html: { class: 'space-y-4' } do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- タイトル検索 -->
        <div>
          <%= f.label :title_cont, 'タイトル', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :title_cont, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: 'タイトルを入力' %>
        </div>

        <!-- 広告種別検索 -->
        <div>
          <%= f.label :ad_type_eq, '広告種別', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.select :ad_type_eq, 
              options_for_select([['全て', ''], ['画像', 'image'], ['動画', 'video']], params.dig(:q, :ad_type_eq)), 
              {}, 
              class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500' %>
        </div>

        <!-- 広告サイズ検索 -->
        <div>
          <%= f.label :ad_size_eq, '広告サイズ', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.select :ad_size_eq, 
              options_for_select([['全て', ''], ['縦長', 'vertical'], ['横長', 'horizontal'], ['正方形', 'square']], params.dig(:q, :ad_size_eq)), 
              {}, 
              class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500' %>
        </div>

        <!-- アクティブ状態検索 -->
        <div>
          <%= f.label :active_eq, 'アクティブ状態', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.select :active_eq, 
              options_for_select([['全て', ''], ['アクティブ', true], ['非アクティブ', false]], params.dig(:q, :active_eq)), 
              {}, 
              class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500' %>
        </div>

        <!-- タグ検索 -->
        <div>
          <%= f.label :tags_cont, 'タグ', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :tags_cont, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: 'タグを入力' %>
        </div>
      </div>

      <div class="flex justify-end space-x-2 pt-4">
        <%= f.submit '検索', class: 'bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded' %>
        <%= link_to 'クリア', advertisements_path, class: 'bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded' %>
      </div>
    <% end %>
  </div>

  <!-- 検索結果 -->
  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-xl font-semibold">
        検索結果 (<%= @advertisements.count %>件)
      </h2>
    </div>

    <% if @advertisements.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">タイトル</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">種別</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">サイズ</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">状態</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">タグ</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">作成日</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @advertisements.each do |advertisement| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900">
                    <%= link_to advertisement.title, advertisement_path(advertisement), class: 'text-blue-600 hover:text-blue-900' %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full <%= advertisement.ad_type == 'image' ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800' %>">
                    <%= advertisement.ad_type == 'image' ? '画像' : '動画' %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">
                    <%= case advertisement.ad_size
                        when 'vertical' then '縦長'
                        when 'horizontal' then '横長'
                        when 'square' then '正方形'
                        end %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if advertisement.active? %>
                    <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                      アクティブ
                    </span>
                  <% else %>
                    <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">
                      非アクティブ
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm text-gray-900">
                    <% if advertisement.tags.any? %>
                      <% advertisement.tags.each do |tag| %>
                        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-800 mr-1 mb-1">
                          <%= tag %>
                        </span>
                      <% end %>
                    <% else %>
                      <span class="text-gray-400">タグなし</span>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= advertisement.created_at.strftime('%Y/%m/%d %H:%M') %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-2">
                    <%= link_to '詳細', advertisement_path(advertisement), class: 'text-blue-600 hover:text-blue-900' %>
                    <%= link_to '編集', edit_advertisement_path(advertisement), class: 'text-indigo-600 hover:text-indigo-900' %>
                    <%= link_to '削除', advertisement_path(advertisement), 
                        method: :delete, 
                        data: { confirm: '本当に削除しますか？' }, 
                        class: 'text-red-600 hover:text-red-900' %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- ページネーション -->
      <div class="px-6 py-4 border-t border-gray-200">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <div class="text-sm text-gray-700">
              <span class="font-medium"><%= @advertisements.offset_value + 1 %></span>
              から
              <span class="font-medium"><%= @advertisements.offset_value + @advertisements.length %></span>
              までを表示
              （全<%= @advertisements.total_count %>件中）
            </div>
            
            <!-- 表示件数選択 -->
            <div class="flex items-center space-x-2">
              <label for="per_page" class="text-sm text-gray-700">表示件数:</label>
              <select id="per_page" name="per_page" class="text-sm border border-gray-300 rounded px-2 py-1" onchange="changePerPage(this.value)">
                <option value="10" <%= 'selected' if params[:per_page] == '10' %>>10件</option>
                <option value="20" <%= 'selected' if params[:per_page] == '20' || params[:per_page].blank? %>>20件</option>
                <option value="50" <%= 'selected' if params[:per_page] == '50' %>>50件</option>
                <option value="100" <%= 'selected' if params[:per_page] == '100' %>>100件</option>
              </select>
            </div>
          </div>
          
          <div class="flex justify-center">
            <%= paginate @advertisements %>
          </div>
        </div>
      </div>

      <script>
        function changePerPage(value) {
          const url = new URL(window.location);
          url.searchParams.set('per_page', value);
          url.searchParams.delete('page'); // ページを1に戻す
          window.location.href = url.toString();
        }
      </script>
    <% else %>
      <div class="px-6 py-12 text-center">
        <div class="text-gray-500">
          <p class="text-lg">広告が見つかりませんでした</p>
          <p class="mt-2">検索条件を変更するか、新しい広告を作成してください</p>
        </div>
      </div>
    <% end %>
  </div>
</div> 