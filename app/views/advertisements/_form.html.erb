<%= form_with(model: advertisement, local: true, class: "space-y-6") do |form| %>
  <% if advertisement.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(advertisement.errors.count, "error") %> prohibited this advertisement from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% advertisement.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- 基本情報 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">基本情報</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- タイトル -->
      <div class="md:col-span-2">
        <%= form.label :title, 'タイトル *', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= form.text_field :title, 
            class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500',
            placeholder: '広告のタイトルを入力してください' %>
      </div>

      <!-- リンクURL -->
      <div class="md:col-span-2">
        <%= form.label :link_url, 'リンクURL *', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= form.url_field :link_url, 
            class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500',
            placeholder: 'https://example.com' %>
        <p class="mt-1 text-sm text-gray-500">HTTPまたはHTTPSのURLを入力してください</p>
      </div>

      <!-- 画像URL -->
      <div class="md:col-span-2">
        <%= form.label :image_url, '画像URL', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= form.url_field :image_url, 
            class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500',
            placeholder: 'https://example.com/image.jpg' %>
        <p class="mt-1 text-sm text-gray-500">広告画像のURLを入力してください（任意）</p>
      </div>

      <!-- 代替テキスト -->
      <div class="md:col-span-2">
        <%= form.label :alt_text, '代替テキスト', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= form.text_area :alt_text, 
            rows: 3,
            class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500',
            placeholder: '画像が表示されない場合の代替テキストを入力してください' %>
        <p class="mt-1 text-sm text-gray-500">アクセシビリティ向上のため、画像の内容を説明するテキストを入力してください</p>
      </div>
    </div>
  </div>

  <!-- 広告設定 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">広告設定</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- 広告種別 -->
      <div>
        <%= form.label :ad_type, '広告種別 *', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= form.select :ad_type, 
            options_for_select([
              ['画像広告', 'image'],
              ['動画広告', 'video']
            ], advertisement.ad_type),
            { prompt: '広告種別を選択してください' },
            class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500' %>
      </div>

      <!-- 広告サイズ -->
      <div>
        <%= form.label :ad_size, '広告サイズ *', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= form.select :ad_size, 
            options_for_select([
              ['縦長', 'vertical'],
              ['横長', 'horizontal'],
              ['正方形', 'square']
            ], advertisement.ad_size),
            { prompt: '広告サイズを選択してください' },
            class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500' %>
      </div>

      <!-- アクティブ状態 -->
      <div class="md:col-span-2">
        <div class="flex items-center">
          <%= form.check_box :active, 
              class: 'h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded' %>
          <%= form.label :active, 'アクティブにする', class: 'ml-2 block text-sm text-gray-900' %>
        </div>
        <p class="mt-1 text-sm text-gray-500">チェックすると広告が表示されます</p>
      </div>
    </div>
  </div>

  <!-- タグ設定 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">タグ設定</h3>
    
    <div>
      <%= form.label :tag_list, 'タグ *', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= form.text_field :tag_list, 
          class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500',
          placeholder: 'タグ1, タグ2, タグ3' %>
      <p class="mt-1 text-sm text-gray-500">カンマ区切りでタグを入力してください</p>
    </div>
  </div>

  <!-- プレビュー -->
  <% if advertisement.image_url.present? %>
    <div class="bg-white shadow rounded-lg p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">プレビュー</h3>
      
      <div class="border border-gray-200 rounded-lg p-4">
        <div class="flex items-center space-x-4">
          <div class="flex-shrink-0">
            <img src="<%= advertisement.image_url %>" 
                 alt="<%= advertisement.alt_text %>" 
                 class="h-16 w-16 object-cover rounded"
                 onerror="this.style.display='none'">
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 truncate">
              <%= advertisement.title %>
            </p>
            <p class="text-sm text-gray-500 truncate">
              <%= advertisement.link_url %>
            </p>
            <div class="mt-1 flex space-x-2">
              <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full 
                          <%= advertisement.ad_type == 'image' ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800' %>">
                <%= advertisement.ad_type == 'image' ? '画像' : '動画' %>
              </span>
              <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">
                <%= case advertisement.ad_size
                    when 'vertical' then '縦長'
                    when 'horizontal' then '横長'
                    when 'square' then '正方形'
                    end %>
              </span>
              <% if advertisement.active? %>
                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                  アクティブ
                </span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- ボタン -->
  <div class="flex justify-end space-x-3">
    <%= link_to 'キャンセル', advertisements_path, 
        class: 'px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500' %>
    <%= form.submit class: 'px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500' %>
  </div>
<% end %>
